modules = ["web", "python-3.11", "nodejs-20", "bash"]
run = "python main.py"

[nix]
channel = "stable-24_05"
packages = ["openssl", "postgresql", "sqlite"]

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "gunicorn --bind 0.0.0.0:5000 main:app"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[workflows.workflow]]
name = "Run Dagster Server"
author = 42433692
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "dagit -h 0.0.0.0 -p 3000"

[[ports]]
localPort = 5000
externalPort = 80
